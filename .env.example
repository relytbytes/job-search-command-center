# ─────────────────────────────────────────────────────────────
# Job Search Command Center — environment configuration
# Copy this file to .env.local and fill in your values.
# The app runs WITHOUT any of these (using bundled demo data),
# but the automatic features need them.
# ─────────────────────────────────────────────────────────────

# ── Google Sheets (the live backing store) ──────────────────
# 1. Create a Google Cloud project + enable the Google Sheets API.
# 2. Create a Service Account, download its JSON key.
# 3. Share your spreadsheet with the service account email (Editor).
# 4. Put the spreadsheet ID (from its URL) below.
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# Paste the private_key from the JSON. Keep the \n escapes OR wrap the whole
# value in double quotes with real newlines. Example:
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=
# The tab that holds the tracker rows (defaults to "Tracker").
SHEET_TAB=Tracker

# ── Job-search API (recommended new listings) ───────────────
# Pick ONE provider. Leaving all blank shows sample listings.
# JOB_API_PROVIDER=adzuna | jsearch | serpapi   (auto-detected if unset)
JOB_API_PROVIDER=

# Adzuna — free tier, https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# JSearch (RapidAPI) — indexes Google-for-Jobs incl. LinkedIn/ZipRecruiter/Indeed
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# SerpAPI — Google Jobs engine, https://serpapi.com/
SERPAPI_KEY=

# Where recommendations are centered (city, state). Defaults to Durham, NC — a
# ~30mi (50km) radius from Durham covers the whole Triangle (Hillsborough,
# Chapel Hill, Creedmoor, RTP, Morrisville, Cary, Raleigh).
JOB_SEARCH_LOCATION=Durham, North Carolina

# ── Writing assistant (cover letters + follow-ups) ──────────
# Enables the "Application Assistant" in each role's drawer. Works with EITHER
# provider — set whichever key you have. If both are set, OpenAI is used
# (override with GEN_PROVIDER=openai|anthropic).

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (https://console.anthropic.com/) — alternative to OpenAI
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Optional: force a provider when both keys are present.
GEN_PROVIDER=
# Optional: override the candidate profile used for generation (defaults to the
# bundled resume in lib/resume.ts). Paste full resume text to personalize.
CANDIDATE_PROFILE=
